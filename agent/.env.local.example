# Agent environment — copy to .env.local and fill in for local dev.
#
# Step 1 does not require these yet; they are consumed starting in Step 2
# when the agent connects to the local LiveKit server.

LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

