# Frontend environment — copy to .env.local and fill in for local dev.
#
# LiveKit server URL (ws://127.0.0.1:7880 when running `livekit-server --dev`)
VITE_LIVEKIT_URL=ws://127.0.0.1:7880

# Room name — must match what the agent joins.
VITE_LIVEKIT_ROOM=coach-room

# LiveKit API key / secret.
# Defaults (when these are unset) match `livekit-server --dev`:
#   key = "devkey", secret = "secret"
# A fresh access token is minted in the browser on every page load with a
# random participant identity (see src/token.ts). Refresh works because
# each page load has a unique identity.
#VITE_LIVEKIT_API_KEY=devkey
#VITE_LIVEKIT_API_SECRET=secret
