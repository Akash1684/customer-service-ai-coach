# Frontend environment — copy to .env.local and fill in for local dev.
#
# Step 1 does not require these yet; they are consumed starting in Step 2
# when the browser connects to the local LiveKit server.

# LiveKit server URL (ws://127.0.0.1:7880 when running `livekit-server --dev` locally)
VITE_LIVEKIT_URL=ws://127.0.0.1:7880

# Long-lived dev token — generate once with:
#   lk token create --api-key devkey --api-secret secret \
#       --join --room coach-room --identity rep-local --valid-for 720h
VITE_LIVEKIT_TOKEN=

# Room name must match the token
VITE_LIVEKIT_ROOM=coach-room
